"VertexLitGeneric"
{
    "$basetexture" "models/molda/toyota_int/telepathics2"

    "$surfaceprop" "Metal"

    "$selfillum" "1"
    "$selfillummask" "models/molda/toyota_int/white"
    "$selfillumtint" "[1 1 1]"
    "$color2" "[1 1 1]"

    "$nodecal" "1"
    "$nocull" "0"

    $sine_basic 1
    $sine_use 0
    $sine_add 1
    $sine_r 1
    $sine_g 1
    $sine_b 1

    "Proxies"
    {
        TARDIS_DefaultInt_TelepathicsAddColor {
            resultVar "$sine_add"
        }
        Sine
        {
            sineperiod 2
            sinemin 1
            sinemax 1.3
            resultVar "$sine_r"
        }
        Sine
        {
            sineperiod 4
            timeoffset 1
            sinemin 1
            sinemax 1.5
            resultVar "$sine_g"
        }
        Add
        {
            srcVar1 $sine_r
            srcVar2 $sine_add
            resultVar "$color2[0]"
        }
        Add
        {
            srcVar1 $sine_g
            srcVar2 $sine_add
            resultVar "$color2[1]"
        }
    }
}
