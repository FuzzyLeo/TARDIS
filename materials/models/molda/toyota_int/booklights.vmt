"VertexLitGeneric"
{
	"$basetexture" "models/molda/toyota_int/booklights"

	"$selfillum" 1
	"$selfillummask" "models/molda/toyota_int/booklights"
	"$selfillumtint_on" "[2 2 2]"
	"$selfillumtint_off" "[0 0 0]"

	"$surfaceprop" "Metal"

	"$nodecal" "1"
	"$nocull" "0"

	Proxies {
		TARDIS_Power {
			onVar "$selfillumtint_on"
			offVar "$selfillumtint_off"
			resultVar "$selfillumtint"
		}
	}

}
