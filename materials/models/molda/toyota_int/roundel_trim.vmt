"VertexLitGeneric"
{
	"$basetexture" "models/molda/toyota_int/bulbs"
	"$surfaceprop" "Metal"

	"$selfillum" 1
	"$selfillummask" "models/molda/toyota_int/white"
	"$selfillumtint" "[1 1 1]"

	"$nodecal" "1"
	"$nocull" "0"

	$speed 10
	$frame 0

	$sine 1

	$envmaptint_on "[0.5 0.5 0.5]"
	$envmaptint_off "[0.05 0.05 0.05]"
	$color2_on "[1.8 0.9 0.6]"
	$color2_off "[0.3 0.3 0.3]"

	Proxies {
		TARDIS_Power {
			onVar "$envmaptint_on"
			offVar "$envmaptint_off"
			resultVar "$envmaptint"
		}
		TARDIS_Power2 {
			onVar "$color2_on"
			offVar "$color2_off"
			resultVar "$color2"
		}
		TARDIS_State_Texture {
			resultTextureVar $basetexture
			resultFrameVar $frame

			textures {
				dead "off"

				off "models/molda/toyota_int/bulbs_off"
				idle "models/molda/toyota_int/bulbs"
				handbrake "idle"

				travel { "models/molda/toyota_int/bulbs_travel" 15 }
				takeoff { "models/molda/toyota_int/bulbs_travel" 5 }
				parking { "models/molda/toyota_int/bulbs_travel" 15 }

				demat_abort "idle"
				demat_fail { "models/molda/toyota_int/roundel_trim_warning" 5 }
				mat_fail { "models/molda/toyota_int/roundel_trim_warning" 5 }


				off_warning "off"
				idle_warning { "models/molda/toyota_int/roundel_trim_warning" 5 }
				handbrake_warning "models/molda/toyota_int/roundel_trim_warning"

				travel_warning { "models/molda/toyota_int/roundel_trim_warning" 5 }
				takeoff_warning { "models/molda/toyota_int/roundel_trim_warning" 5 }
				parking_warning "takeoff_warning"

				demat_abort_warning "idle_warning"
				demat_fail_warning { "models/molda/toyota_int/roundel_trim_warning" 5 }
				mat_fail_warning "takeoff_warning"
			}
		}
		Sine {
			sineperiod 4
			sinemin 0.8
			sinemax 1
			resultVar $sine
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[0]"
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[1]"
		}
		Equals {
			srcVar1 $sine
			resultVar "$selfillumtint[2]"
		}
	}
}

