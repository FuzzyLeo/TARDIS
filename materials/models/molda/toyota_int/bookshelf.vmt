"VertexLitGeneric"
{
	"$basetexture" "models/molda/toyota_int/bookshelf"
	"$surfaceprop" "Metal"

	"$envmap" "models/molda/toyota_int/environment"
	"$envmaptint_on" "[0.2 0.2 0.2]"
	"$envmaptint_off" "[0 0 0]"

	"$nodecal" "1"
	"$nocull" "0"

	Proxies {
		TARDIS_Power {
			onVar "$envmaptint_on"
			offVar "$envmaptint_off"
			resultVar "$envmaptint"
		}
	}

}
