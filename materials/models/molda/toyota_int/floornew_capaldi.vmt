"VertexLitGeneric"
{
	"$basetexture" "models/molda/toyota_int/floornew"

	"$color2" "[1 1 0.9]"

	"$surfaceprop" "Metal"

	"$envmap" "models/molda/toyota_int/environment"
//	"$envmaptint" "[0.32 0.35 0.35]"
	"$envmaptint_on" "[0 0.7 0.8]"
	"$envmaptint_off" "[0 0 0]"
	"$envmapmask" "models/molda/toyota_int/smudgeN"

	"$nodecal" "1"
	"$nocull" "0"

	$envmaptint_mult "0.6"
	$envmaptint_mult_on "0.6"
	$envmaptint_mult_off "0"
	$envmaptint_color "[1.5 0.9 0.6]"
	Proxies {
		TARDIS_Power {
			onVar "$envmaptint_mult_on"
			offVar "$envmaptint_mult_off"
			resultVar $envmaptint_mult
		}
		Multiply {
			srcVar1 $envmaptint_color
			srcVar2 $envmaptint_mult
			resultVar $envmaptint
		}
	}
}
