"VertexLitGeneric"
{
    "$basetexture" "models/molda/toyota_int/telepathics"

    "$surfaceprop" "Metal"

    "$selfillum" "1"
    "$selfillummask" "models/molda/toyota_int/white"
    "$selfillumtint" "[0.3 0.3 0.3]"
    "$color2" "[1 1 1]"

    "$nodecal" "1"
    "$nocull" "0"

    $sine_basic 1
    $sine_use 0
    $sine_add 1
    $sine_r 1
    $sine_g 1
    $sine_b 1

    "Proxies"
    {
        TARDIS_DefaultInt_TelepathicsAddColor {
            resultVar "$sine_add"
        }
        Sine
        {
            sineperiod 5
            sinemin 0
            sinemax 0.7
            resultVar "$sine_r"
        }
        Sine
        {
            sineperiod 5
            timeoffset 0.5
            sinemin 0.8
            sinemax 1.4
            resultVar "$sine_g"
        }
        Sine
        {
            sineperiod 5
            timeoffset 2
            sinemin 1
            sinemax 1.8
            resultVar "$sine_b"
        }
        Add
        {
            srcVar1 $sine_r
            srcVar2 $sine_add
            resultVar "$color2[0]"
        }
        Add
        {
            srcVar1 $sine_g
            srcVar2 $sine_add
            resultVar "$color2[1]"
        }
        Add
        {
            srcVar1 $sine_b
            srcVar2 $sine_add
            resultVar "$color2[2]"
        }

    }
}
