"VertexLitGeneric"
{
    "$basetexture" "models/molda/toyota_int/telepathics"

    "$surfaceprop" "Metal"

    "$selfillum" "1"
    "$selfillummask" "models/molda/toyota_int/white"
    "$selfillumtint" "[2 2 2]"
    "$color2" "[1 1 1]"

    "$nodecal" "1"
    "$nocull" "0"

    $sine_add 1
    $sine_r 1
    $sine_g 1
    $sine_b 1

    "Proxies"
    {
        TARDIS_DefaultInt_TelepathicsAddColor {
            resultVar "$sine_add"
        }
        Sine
        {
            sineperiod 10
            sinemin 0.9
            sinemax 1.1
            resultVar "$sine_r"
        }
        Sine
        {
            sineperiod 10
            timeoffset 1
            sinemin 0.9
            sinemax 1.1
            resultVar "$sine_g"
        }
        Sine
        {
            sineperiod 10
            timeoffset 4
            sinemin 0.9
            sinemax 1.1
            resultVar "$sine_b"
        }
        Add
        {
            srcVar1 $sine_r
            srcVar2 $sine_add
            resultVar "$color2[0]"
        }
        Add
        {
            srcVar1 $sine_g
            srcVar2 $sine_add
            resultVar "$color2[1]"
        }
        Add
        {
            srcVar1 $sine_b
            srcVar2 $sine_add
            resultVar "$color2[2]"
        }

    }
}
