"VertexLitGeneric"
{
	"$basetexture" "models/molda/misc/tardis_pumpkin"
	"$surfaceprop" "Watermelon"

	"$color2"            "[2 2 2]"
	"$envmap"            "models/molda/mccc/environment"
	"$envmaptint"        "[0.35 0.25 0.25]"

	"$selfillum"         "1"
	"$selfillummask"     "models/molda/misc/tardis_pumpkin_emit"

	"$nocull" "0"
	"$nodecal" "1"

	"$sine1" "1"
	"$sine2" "1"
	"$sine3" "1"
	"$sinesum" "1"
	"$sineall" "1"
	"$sineavg" "1"
	"$layers" "0.333333"

	Proxies
	{
		Sine { sineperiod 1.30  sinemin 0.70  sinemax 2  resultVar $sine1 }
		Sine { sineperiod 0.54  sinemin 0.60  sinemax 2  resultVar $sine2 }
		Sine { sineperiod 0.24  sinemin 0.85  sinemax 2  resultVar $sine3 }

		Add      { srcVar1 $sine1    srcVar2 $sine2      resultVar $sinesum }
		Add      { srcVar1 $sinesum  srcVar2 $sine3      resultVar $sinesum }
		Multiply { srcVar1 $sinesum  srcVar2 $layers     resultVar $sineavg }

		Equals { srcVar1 $sineavg resultVar "$selfillumtint[0]" }
		Equals { srcVar1 $sineavg resultVar "$selfillumtint[1]" }
		Equals { srcVar1 $sineavg resultVar "$selfillumtint[2]" }
	}
}
