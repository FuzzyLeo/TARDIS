"VertexlitGeneric"
{
	"$basetexture" "models/artixc/exteriors/sidrat"
	"$envmap" "models/artixc/exteriors/environment"
	"$envmaptint" "[0.2 0.2 0.2]"
	"$nodecal" "1"
	"$surfaceprop" "Glass"

	"$envmapdarken" "0.14"

	"$envmapcolor" "[1 1 1]"

	"Proxies"
	{
		TARDIS_ExteriorBaseLight
		{
			defaultColor "$envmaptint"
			resultVar "$envmapcolor"
		}

		Multiply
		{
			srcVar1	"$envmapcolor"
			srcVar2		"$envmapdarken"
			resultVar "$envmaptint"
		}

	}

}


