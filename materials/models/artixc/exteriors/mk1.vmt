"VertexlitGeneric"
{
	"$basetexture" "models/artixc/exteriors/mk1"
	"$envmap" "models/artixc/exteriors/environment"
	"$envmaptint" "[0.3 0.3 0.3]"
	"$nodecal" "1"
	"$surfaceprop" "Glass"


	"$envmapdarken" "0.25"

	"$envmapcolor" "[1 1 1]"

	"Proxies"
	{
		TARDIS_ExteriorBaseLight
		{
			defaultColor "$envmaptint"
			resultVar "$envmapcolor"
		}

		Multiply
		{
			srcVar1	"$envmapcolor"
			srcVar2		"$envmapdarken"
			resultVar "$envmaptint"
		}

	}

}


