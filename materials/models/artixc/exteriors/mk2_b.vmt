"VertexlitGeneric"
{
	"$basetexture" "models/artixc/exteriors/mk2"
	"$nodecal" "1"
	"$surfaceprop" "Metal"

	"$color2"	"[0.85 0.85 0.9]"

	"$envmap" "models/artixc/exteriors/environment"
	"$envmaptint" "[0.3 0.3 0.3]"

	"$detail"				"detail/metal_detail_01"
	"$detailscale"			"8.4"
	"$detailblendfactor"	"0.05"
	"$detailblendmode"		"0"

	"$phong"					"1"
	"$phongexponent"			"10"
	"$phongboost"				"10"

	"$envmapdarken" "0.2"

	"$envmapcolor" "[1 1 1]"

	"Proxies"
	{
		TARDIS_ExteriorBaseLight
		{
			defaultColor "$envmaptint"
			resultVar "$envmapcolor"
		}

		Multiply
		{
			srcVar1	"$envmapcolor"
			srcVar2		"$envmapdarken"
			resultVar "$envmaptint"
		}

	}

}


